@baseUrl = https://localhost:7123
@sessionId = paste-session-id-here

### Register
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "name": "Test User",
  "phoneNumber": "0791234567",
  "password": "123456",
  "mallID": "00000000-0000-0000-0000-000000000001"
}

### Manager Quick Login
POST {{baseUrl}}/api/auth/manager-quick-login
Content-Type: application/json

{
  "managerId": "491ead79-af30-44f6-ac53-d835e5889e72"
}

### Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "phoneNumber": "0791234567",
  "password": "123456",
  "mallID": "00000000-0000-0000-0000-000000000001"
}

### Logout
POST {{baseUrl}}/api/auth/logout
Content-Type: application/json

{
  "sessionId": "{{sessionId}}"
}

### Get User Points
GET {{baseUrl}}/api/userinfo/points
X-Session-Id: {{sessionId}}

### Get Coupons
GET {{baseUrl}}/api/coupons?isActive=true
X-Session-Id: {{sessionId}}

### Get User Coupons
GET {{baseUrl}}/api/coupons/user
X-Session-Id: {{sessionId}}

### Get Offers
GET {{baseUrl}}/api/offers
X-Session-Id: {{sessionId}}

### Get Stores
GET {{baseUrl}}/api/stores
X-Session-Id: {{sessionId}}

### Get Store By ID
GET {{baseUrl}}/api/stores/00000000-0000-0000-0000-000000000003
X-Session-Id: {{sessionId}}

### Redeem Coupon
POST {{baseUrl}}/api/coupons/redeem
Content-Type: application/json
X-Session-Id: {{sessionId}}

{
  "couponId": "00000000-0000-0000-0000-000000000002"
}

### Redeem Coupon By Serial
POST {{baseUrl}}/api/coupons/redeem-by-serial
Content-Type: application/json

{
  "serialNumber": "12345678"
}

### Add Transaction
POST {{baseUrl}}/api/transactions
Content-Type: application/json

{
  "phoneNumber": "0791234567",
  "storeId": "00000000-0000-0000-0000-000000000003",
  "receiptId": "receipt-001",
  "receiptDescription": "Test receipt",
  "price": 19.99
}

### Get Receipt By ID
GET {{baseUrl}}/api/transactions/1
X-Session-Id: {{sessionId}}

### Get My Receipts
GET {{baseUrl}}/api/transactions/my-receipts?page=1&pageSize=20
X-Session-Id: {{sessionId}}

### Get Announcements
GET {{baseUrl}}/api/announcements
X-Session-Id: {{sessionId}}

### Ask Chatbot
POST {{baseUrl}}/api/chatbot/ask
Content-Type: application/json

{
  "msg": "What are the mall opening hours?"
}

### Get Chatbot History
GET {{baseUrl}}/api/chatbot/history

### Get Managed Stores
GET {{baseUrl}}/api/stores/manage
X-Session-Id: {{sessionId}}

### Create Store
POST {{baseUrl}}/api/stores
Content-Type: application/json
X-Session-Id: {{sessionId}}

{
  "name": "New Shop",
  "operatingHours": "9 AM - 10 PM",
  "description": "New test store",
  "phoneNumber": "+962799999999",
  "email": "newshop@example.com",
  "floorNumber": "Second Floor",
  "categoryIds": [11, 12]
}

### Update Store
PUT {{baseUrl}}/api/stores/00000000-0000-0000-0000-000000000003
Content-Type: application/json
X-Session-Id: {{sessionId}}

{
  "name": "Updated Shop",
  "operatingHours": "10 AM - 11 PM",
  "description": "Updated description",
  "phoneNumber": "+962788888888",
  "email": "updatedshop@example.com",
  "floorNumber": "Ground Floor",
  "categoryIds": [11]
}

### Get Managed Offers
GET {{baseUrl}}/api/offers/manage
X-Session-Id: {{sessionId}}

### Create Offer
POST {{baseUrl}}/api/offers
Content-Type: application/json
X-Session-Id: {{sessionId}}

{
  "storeId": "00000000-0000-0000-0000-000000000003",
  "title": "Weekend Sale",
  "description": "20% off selected items",
  "startAt": "2026-04-18T09:00:00Z",
  "endAt": "2026-04-25T21:00:00Z",
  "isActive": true
}

### Update Offer
PUT {{baseUrl}}/api/offers/1
Content-Type: application/json
X-Session-Id: {{sessionId}}

{
  "storeId": "00000000-0000-0000-0000-000000000003",
  "title": "Weekend Sale Updated",
  "description": "25% off selected items",
  "startAt": "2026-04-18T09:00:00Z",
  "endAt": "2026-04-26T21:00:00Z",
  "isActive": true
}

### Set Offer Status
PATCH {{baseUrl}}/api/offers/1/status
Content-Type: application/json
X-Session-Id: {{sessionId}}

{
  "isActive": false
}

### Delete Offer
DELETE {{baseUrl}}/api/offers/1
X-Session-Id: {{sessionId}}

### Get Managed Announcements
GET {{baseUrl}}/api/announcements/manage
X-Session-Id: {{sessionId}}

### Create Announcement
POST {{baseUrl}}/api/announcements
Content-Type: application/json
X-Session-Id: {{sessionId}}

{
  "title": "Mall Event",
  "content": "Live music this weekend",
  "announcementType": "event",
  "priority": "high",
  "startDate": "2026-04-18T09:00:00Z",
  "endDate": "2026-04-22T21:00:00Z",
  "isActive": true,
  "isPinned": true
}

### Update Announcement
PUT {{baseUrl}}/api/announcements/00000000-0000-0000-0000-000000000001
Content-Type: application/json
X-Session-Id: {{sessionId}}

{
  "title": "Mall Event Updated",
  "content": "Live music and food festival",
  "announcementType": "event",
  "priority": "high",
  "startDate": "2026-04-18T09:00:00Z",
  "endDate": "2026-04-23T21:00:00Z",
  "isActive": true,
  "isPinned": true
}

### Set Announcement Status
PATCH {{baseUrl}}/api/announcements/00000000-0000-0000-0000-000000000001/status
Content-Type: application/json
X-Session-Id: {{sessionId}}

{
  "isActive": false
}

### Set Announcement Pin
PATCH {{baseUrl}}/api/announcements/00000000-0000-0000-0000-000000000001/pin
Content-Type: application/json
X-Session-Id: {{sessionId}}

{
  "isPinned": true
}

### Delete Announcement
DELETE {{baseUrl}}/api/announcements/00000000-0000-0000-0000-000000000001
X-Session-Id: {{sessionId}}

