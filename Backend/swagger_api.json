  "components": {
    "schemas": {
      "AddTransactionDto": {
        "required": [
          "phoneNumber",
          "price",
          "receiptId",
          "storeId"
        ],
        "type": "object",
        "properties": {
          "phoneNumber": {
            "minLength": 1,
            "type": "string"
          },
          "storeId": {
            "type": "string",
            "format": "uuid"
          },
          "receiptId": {
            "minLength": 1,
            "type": "string"
          },
          "receiptDescription": {
            "type": "string",
            "nullable": true
          },
          "price": {
            "minimum": 0,
            "type": "number",
