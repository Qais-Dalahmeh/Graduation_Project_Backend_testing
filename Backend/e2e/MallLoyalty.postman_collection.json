          }
        },

        {
          "name": "Manager — Create store",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 2xx', () => pm.expect(pm.response.code).to.be.lessThan(300));",
                "pm.test('Has id and name', () => {",
                "  const body = pm.response.json();",
                "  pm.expect(body).to.have.property('id');",
                "  pm.collectionVariables.set('createdStoreId', body.id);",
