              { "key": "X-Session-Id", "value": "{{managerSessionId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"E2E Postman Store\",\n  \"description\": \"Created by Postman automated test\",\n  \"floorNumber\": \"1\",\n  \"operatingHours\": \"9:00 AM - 10:00 PM\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/stores", "host": ["{{baseUrl}}"], "path": ["api","stores"] }
          }
        },

        {
          "name": "Manager — Update store",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
