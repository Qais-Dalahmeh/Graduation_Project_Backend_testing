        }

      ]
    },

    {
      "name": "06 — Offers",
      "item": [

        {
          "name": "Manager — Create offer",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 2xx', () => pm.expect(pm.response.code).to.be.lessThan(300));",
                "pm.test('Has id', () => {",
                "  pm.collectionVariables.set('offerId', pm.response.json().id);",
                "});",
                "pm.test('isActive true', () => pm.expect(pm.response.json().isActive).to.be.true);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Session-Id", "value": "{{managerSessionId}}" }
            ],
