              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Session-Id", "value": "{{sessionId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Illegal Store\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/stores", "host": ["{{baseUrl}}"], "path": ["api","stores"] }
