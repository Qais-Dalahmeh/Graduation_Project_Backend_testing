# Copy this file to .env.test and fill in your values
# Never commit .env.test to git

# Base URL of the running backend
BASE_URL=http://localhost:5000

# Mall ID used for test users (must exist in DB)
TEST_MALL_ID=1

# A manager ID that already exists in the DB (for manager quick-login tests)
TEST_MANAGER_ID=1

# A store ID that already exists in the DB (for transaction tests)
TEST_STORE_ID=1
